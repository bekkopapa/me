{
  "firestore": {
    "database": "(default)",
    "location": "nam5",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": {
    "source": "functions"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/chat",
        "function": "apiChat"
      },
      {
        "source": "/api/chat2",
        "function": "apiChat2"
      },
      {
        "source": "/api/chat3",
        "function": "apiChat3"
      },
      {
        "source": "/api/uploadUrl",
        "function": "generateUploadUrl"
      }
    ]
  }
}
