rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 갤러리 파일: 누구나 읽기 가능, 인증된 사용자만 쓰기 가능
    match /gallery/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // 업로드 임시 파일 등: 인증된 사용자만 접근 가능
    match /uploads/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // 기본 규칙
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
